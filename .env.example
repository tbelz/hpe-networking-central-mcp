# HPE Aruba Networking Central - MCP Server Configuration
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# .env is gitignored and will never be committed.

# Required: Central API credentials
CENTRAL_BASE_URL=https://internal.api.central.arubanetworks.com
CENTRAL_CLIENT_ID=
CENTRAL_CLIENT_SECRET=

# Knowledge database: GitHub repo that publishes knowledge_db.tar.gz releases
KNOWLEDGE_RELEASE_REPO=tbelz/hpe-networking-central-mcp
