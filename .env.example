# HPE Aruba Networking Central - MCP Server Configuration
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# .env is gitignored and will never be committed.

# Required: Central API credentials
CENTRAL_BASE_URL=https://internal.api.central.arubanetworks.com
CENTRAL_CLIENT_ID=
CENTRAL_CLIENT_SECRET=

# Optional: Postman API key for dynamic API endpoint discovery
# Without this, the API catalog will be empty (you can still use call_central_api if you know the path)
POSTMAN_API_KEY=
